# Copy this file to .envrc and fill in your values, then run `direnv allow`.

# Anthropic API key (required for `fbm chat` and `fbm discord`)
export ANTHROPIC_API_KEY=

# Discord bot token (required for `fbm discord`)
export FBM_DISCORD_TOKEN=

# Yahoo Fantasy API OAuth credentials
# These override the corresponding fields in fbm.toml.
export FBM_YAHOO_CLIENT_ID=
export FBM_YAHOO_CLIENT_SECRET=

# Optional: override the default league from fbm.toml
# export FBM_YAHOO_LEAGUE=
